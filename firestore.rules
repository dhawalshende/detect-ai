rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Inspections: users can only read/write their own documents
    match /inspections/{docId} {
      // Allow create: the authenticated user must match the userId field in the new doc
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId;

      // Allow read, update, delete: the authenticated user must match the stored userId
      allow read, update, delete: if request.auth != null
                                   && request.auth.uid == resource.data.userId;
    }

    // Block everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
